{
  "expo": {
    "name": "youtube",
    "slug": "youtube",
    "version": "1.0.0",
    "orientation": "landscape",
    "icon": "./assets/images/splash-icon.png",
    "scheme": "youtube",
    "userInterfaceStyle": "dark",
    "isTV": true,
    "newArchEnabled": true,
    "nativewind": {
      "output": "native"
    },
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#030303"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.youtubekids.youtube"
    },
    "android": {
      "package": "com.youtubekids.youtube",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/splash-icon.png",
        "backgroundColor": "#030303"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-web-browser",
      "expo-video",
      "expo-sqlite",
      "expo-image"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "f7d9ab50-2619-44fa-b666-035e40de778a"
      }
    },
    "owner": "youtubekids"
  }
}
